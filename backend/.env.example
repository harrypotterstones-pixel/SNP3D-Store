# MongoDB Atlas connection string example
# Replace <username>, <password>, and <cluster-url> with your Atlas values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/snp3d?retryWrites=true&w=majority

# JWT secret for signing tokens (use a long random string in production)
JWT_SECRET=super-secret-change-me

# Frontend URL (used for CORS and verification links)
FRONTEND_URL=https://snp3d.ca

# SMTP settings for verification and password reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-email-password

# Admin account defaults used by seed script (change immediately)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@snp3d.ca
ADMIN_PASSWORD=ChangeMe123!

# Server port
PORT=3001
